{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "KoliseuOT-Launcher",
  "version": "1.0.6",
  "identifier": "com.koliseuot.launcher",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "KoliseuOT Launcher",
        "width": 900,
        "height": 550,
        "resizable": false,
        "fullscreen": false,
        "decorations": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "icon": [
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true,
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://koliseuot.com.br/api/launcher/updates/{{current_version}}"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IENGRkJCRDM4ODYyRkZCOEEKUldTSyt5K0dPTDM3ejBaQS83RDJpeVE5VkpFK000WnIzS0RZWTN1Vm1GbnovZkpPeEk4bDdscXoK"
    }
  }
}